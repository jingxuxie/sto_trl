+import jax
+import jax.numpy as jnp
+import optax
+
+from agents.trl_log import get_config as get_trl_log_config
+from agents.trl_log_relax_mc import TRLLogRelaxMCAgent
+
+
+class TRLLogRelaxNegAgent(TRLLogRelaxMCAgent):
+    """One-sided log TRL with MC positives and random-goal negatives."""
+
+    def critic_loss(self, batch, grad_params):
+        _goal_key, _q_logits, pred_z, qs, target_z, _tr_loss = self._log_trl_components(
+            batch, grad_params
+        )
+        improve = jax.lax.stop_gradient(target_z > pred_z)
+        tr_loss = jnp.where(
+            improve,
+            optax.huber_loss(pred_z, target_z, delta=self.config["log_huber_delta"]),
+            0.0,
+        )
+
+        mc_target_z = jax.lax.stop_gradient(
+            jnp.clip(
+                batch["value_offsets"][None, ...] * jnp.log(self.config["discount"]),
+                self.config["log_min"],
+                0.0,
+            )
+        )
+        mc_loss = optax.huber_loss(
+            pred_z, mc_target_z, delta=self.config["log_huber_delta"]
+        )
+
+        random_goal_key = (
+            "value_random_goal_observations"
+            if self.config["oracle_distill"]
+            else "value_random_goals"
+        )
+        neg_logits = self.network.select("critic")(
+            batch["observations"],
+            goals=batch[random_goal_key],
+            actions=batch["actions"],
+            params=grad_params,
+        )
+        neg_loss = optax.sigmoid_binary_cross_entropy(
+            neg_logits, jnp.zeros_like(neg_logits)
+        )
+        neg_qs = jax.nn.sigmoid(neg_logits)
+
+        tr_loss_mean = tr_loss.mean()
+        mc_loss_mean = mc_loss.mean()
+        neg_loss_mean = neg_loss.mean()
+        distill_loss = self._oracle_distill_loss(batch, grad_params, qs)
+        total_loss = (
+            self.config["tr_alpha"] * tr_loss_mean
+            + self.config["mc_alpha"] * mc_loss_mean
+            + self.config["neg_alpha"] * neg_loss_mean
+            + distill_loss
+        )
+
+        return total_loss, {
+            "total_loss": total_loss,
+            "q_loss": tr_loss_mean,
+            "mc_loss": mc_loss_mean,
+            "neg_loss": neg_loss_mean,
+            "distill_loss": distill_loss,
+            "improve_frac": improve.mean(),
+            "z_mean": pred_z.mean(),
+            "z_target_mean": target_z.mean(),
+            "z_mc_target_mean": mc_target_z.mean(),
+            "q_mean": qs.mean(),
+            "q_max": qs.max(),
+            "q_min": qs.min(),
+            "neg_q_mean": neg_qs.mean(),
+        }
+
+
+def get_config():
+    config = get_trl_log_config()
+    config["agent_name"] = "trl_log_relax_neg"
+    config["mc_alpha"] = 1.0
+    config["tr_alpha"] = 1.0
+    config["neg_alpha"] = 0.1
+    return config
