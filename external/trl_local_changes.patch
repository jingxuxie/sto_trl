index 0000000..ec7d6f5
--- /dev/null
+++ b/agents/trl_log.py
@@ -0,0 +1,122 @@
+import jax
+import jax.numpy as jnp
+import optax
+
+from agents.trl import TRLAgent, get_config as get_trl_config
+
+
+class TRLLogAgent(TRLAgent):
+    """Log-space TRL critic.
+
+    The original TRL critic multiplies reachability probabilities and trains
+    with BCE. This variant trains log reachability directly:
+
+        log Q(s,a,g) <- log Q(s,a,w) + log Q(w,a_w,g)
+
+    It is numerically better behaved for long horizons and is the minimal
+    official-code bridge to the stochastic tabular prototype.
+    """
+
+    def _log_trl_components(self, batch, grad_params):
+        goal_key = (
+            "value_goal_observations"
+            if self.config["oracle_distill"]
+            else "value_goals"
+        )
+        q_logits = self.network.select("critic")(
+            batch["observations"],
+            goals=batch[goal_key],
+            actions=batch["actions"],
+            params=grad_params,
+        )
+        pred_z = jax.nn.log_sigmoid(q_logits)
+        qs = jax.nn.sigmoid(q_logits)
+
+        midpoint_goal_key = (
+            "value_midpoint_observations"
+            if self.config["oracle_distill"]
+            else "value_midpoint_goals"
+        )
+        log_discount = jnp.log(self.config["discount"])
+
+        first_q_logits = self.network.select("target_critic")(
+            batch["observations"],
+            goals=batch[midpoint_goal_key],
+            actions=batch["actions"],
+        )
+        first_z = jnp.where(
+            (batch["value_midpoint_offsets"] <= 1)[None, ...],
+            batch["value_midpoint_offsets"][None, ...] * log_discount,
+            jax.nn.log_sigmoid(first_q_logits),
+        )
+        first_z = jnp.clip(first_z, self.config["log_min"], 0.0)
+
+        second_q_logits = self.network.select("target_critic")(
+            batch["value_midpoint_observations"],
+            goals=batch[goal_key],
+            actions=batch["value_midpoint_actions"],
+        )
+        second_offset = (
+            batch["value_offsets"][None, ...] - batch["value_midpoint_offsets"]
+        )
+        second_z = jnp.where(
+            (second_offset <= 1)[None, ...],
+            second_offset * log_discount,
+            jax.nn.log_sigmoid(second_q_logits),
+        )
+        second_z = jnp.clip(second_z, self.config["log_min"], 0.0)
+        target_z = jax.lax.stop_gradient(
+            jnp.clip(first_z + second_z, self.config["log_min"], 0.0)
+        )
+
+        expectile_weight = jnp.where(
+            target_z >= pred_z,
+            self.config["expectile"],
+            (1 - self.config["expectile"]),
+        )
+        dist = jax.lax.stop_gradient(target_z / log_discount)
+        dist_weight = (1 / (1 + dist)) ** self.config["lam"]
+        tr_loss = (
+            expectile_weight
+            * dist_weight
+            * optax.huber_loss(pred_z, target_z, delta=self.config["log_huber_delta"])
+        )
+        return goal_key, q_logits, pred_z, qs, target_z, tr_loss
+
+    def _oracle_distill_loss(self, batch, grad_params, qs):
+        if not self.config["oracle_distill"]:
+            return 0.0
+        distill_q_logits = self.network.select("oracle_critic")(
+            batch["observations"],
+            goals=batch["value_goals"],
+            actions=batch["actions"],
+            params=grad_params,
+        )
+        return self.bce_loss(distill_q_logits, jax.lax.stop_gradient(qs)).mean()
+
+    def critic_loss(self, batch, grad_params):
+        _goal_key, _q_logits, pred_z, qs, target_z, tr_loss = self._log_trl_components(
+            batch, grad_params
+        )
+        q_loss = tr_loss.mean()
+        distill_loss = self._oracle_distill_loss(batch, grad_params, qs)
+        total_loss = q_loss + distill_loss
+
+        return total_loss, {
+            "total_loss": total_loss,
+            "q_loss": q_loss,
+            "distill_loss": distill_loss,
+            "z_mean": pred_z.mean(),
+            "z_target_mean": target_z.mean(),
+            "q_mean": qs.mean(),
+            "q_max": qs.max(),
+            "q_min": qs.min(),
+        }
+
+
+def get_config():
+    config = get_trl_config()
+    config["agent_name"] = "trl_log"
+    config["log_huber_delta"] = 1.0
+    config["log_min"] = -80.0
+    return config
