@@ -0,0 +1,53 @@
+import jax
+import jax.numpy as jnp
+import optax
+
+from agents.trl_log import TRLLogAgent, get_config as get_trl_log_config
+
+
+class TRLLogMCAgent(TRLLogAgent):
+    """Log-space TRL with an on-trajectory MC anchor.
+
+    This is the fast bridge variant from the project plan. It is not the final
+    stochastic algorithm because the MC target still treats realized lucky paths
+    as reliable, but it separates log-space stability from transitive recursion.
+    """
+
+    def critic_loss(self, batch, grad_params):
+        _goal_key, _q_logits, pred_z, qs, target_z, tr_loss = self._log_trl_components(
+            batch, grad_params
+        )
+        mc_target_z = jax.lax.stop_gradient(
+            jnp.clip(
+                batch["value_offsets"][None, ...] * jnp.log(self.config["discount"]),
+                self.config["log_min"],
+                0.0,
+            )
+        )
+        mc_loss = optax.huber_loss(
+            pred_z, mc_target_z, delta=self.config["log_huber_delta"]
+        )
+        q_loss = tr_loss.mean()
+        mc_loss_mean = mc_loss.mean()
+        distill_loss = self._oracle_distill_loss(batch, grad_params, qs)
+        total_loss = q_loss + self.config["mc_alpha"] * mc_loss_mean + distill_loss
+
+        return total_loss, {
+            "total_loss": total_loss,
+            "q_loss": q_loss,
+            "mc_loss": mc_loss_mean,
+            "distill_loss": distill_loss,
+            "z_mean": pred_z.mean(),
+            "z_target_mean": target_z.mean(),
+            "z_mc_target_mean": mc_target_z.mean(),
+            "q_mean": qs.mean(),
+            "q_max": qs.max(),
+            "q_min": qs.min(),
+        }
+
+
+def get_config():
+    config = get_trl_log_config()
+    config["agent_name"] = "trl_log_mc"
+    config["mc_alpha"] = 0.1
+    return config
