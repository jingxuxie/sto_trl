+import jax
+import jax.numpy as jnp
+import optax
+
+from agents.trl_log import TRLLogAgent, get_config as get_trl_log_config
+
+
+class TRLLogRelaxTDAgent(TRLLogAgent):
+    """One-sided log transitive relaxation with stochastic one-step TD.
+
+    The transitive term only lifts predictions when a sampled midpoint gives a
+    better composed path. The TD term is symmetric in probability space so
+    stochastic next-state samples average to a Bellman expectation instead of
+    averaging log probabilities.
+    """
+
+    def critic_loss(self, batch, grad_params):
+        goal_key, _q_logits, pred_z, qs, target_z, _tr_loss = self._log_trl_components(
+            batch, grad_params
+        )
+
+        improve = jax.lax.stop_gradient(target_z > pred_z)
+        tr_loss = jnp.where(
+            improve,
+            optax.huber_loss(pred_z, target_z, delta=self.config["log_huber_delta"]),
+            0.0,
+        )
+
+        log_discount = jnp.log(self.config["discount"])
+        mc_target_z = jax.lax.stop_gradient(
+            jnp.clip(
+                batch["value_offsets"][None, ...] * log_discount,
+                self.config["log_min"],
+                0.0,
+            )
+        )
+        mc_loss = optax.huber_loss(
+            pred_z, mc_target_z, delta=self.config["log_huber_delta"]
+        )
+
+        next_q_logits = self.network.select("target_critic")(
+            batch["next_observations"],
+            goals=batch[goal_key],
+            actions=batch["next_actions"],
+        )
+        td_target_q = self.config["discount"] * jax.nn.sigmoid(next_q_logits)
+        one_step_q = self.config["discount"] ** batch["value_offsets"][None, ...]
+        td_target_q = jnp.where(
+            (batch["value_offsets"] <= 1)[None, ...],
+            one_step_q,
+            td_target_q,
+        )
+        td_target_q = jax.lax.stop_gradient(jnp.clip(td_target_q, 1e-8, 1.0))
+        td_loss = optax.huber_loss(
+            qs, td_target_q, delta=self.config["td_huber_delta"]
+        )
+
+        tr_loss_mean = tr_loss.mean()
+        mc_loss_mean = mc_loss.mean()
+        td_loss_mean = td_loss.mean()
+        distill_loss = self._oracle_distill_loss(batch, grad_params, qs)
+        total_loss = (
+            self.config["tr_alpha"] * tr_loss_mean
+            + self.config["mc_alpha"] * mc_loss_mean
+            + self.config["td_alpha"] * td_loss_mean
+            + distill_loss
+        )
+
+        return total_loss, {
+            "total_loss": total_loss,
+            "q_loss": tr_loss_mean,
+            "mc_loss": mc_loss_mean,
+            "td_loss": td_loss_mean,
+            "distill_loss": distill_loss,
+            "improve_frac": improve.mean(),
+            "z_mean": pred_z.mean(),
+            "z_target_mean": target_z.mean(),
+            "z_mc_target_mean": mc_target_z.mean(),
+            "q_mean": qs.mean(),
+            "q_td_target_mean": td_target_q.mean(),
+            "q_max": qs.max(),
+            "q_min": qs.min(),
+        }
+
+
+def get_config():
+    config = get_trl_log_config()
+    config["agent_name"] = "trl_log_relax_td"
+    config["mc_alpha"] = 0.2
+    config["tr_alpha"] = 1.0
+    config["td_alpha"] = 1.0
+    config["td_huber_delta"] = 0.1
+    return config
diff --git a/agents/trl_log_relax_tdmax.py b/agents/trl_log_relax_tdmax.py
new file mode 100644
index 0000000..24d1f66
--- /dev/null
+++ b/agents/trl_log_relax_tdmax.py
@@ -0,0 +1,131 @@
+import jax
+import jax.numpy as jnp
+import optax
+
+from agents.trl_log import TRLLogAgent, get_config as get_trl_log_config
+
+
+class TRLLogRelaxTDMaxAgent(TRLLogAgent):
+    """Log-space path relaxation with a stochastic Bellman action-max target.
+
+    This is a closer neural analogue of the tabular stochastic backup:
+
+        Q(s, a, g) <- E[s'|s,a] gamma max_a' Q(s', a', g)
+
+    The expectation is represented by sampled dataset next states, while the
+    max is approximated by comparing the dataset next action with a
+    deterministic actor-generated candidate.
+    """
+
+    def _actor_candidate_actions(self, batch, goal_key):
+        pe_type = self.config["pe_type"]
+        if pe_type == "frs":
+            action = jnp.zeros_like(batch["actions"])
+            flow_steps = self.config["frs"]["flow_steps"]
+            for i in range(flow_steps):
+                t = jnp.full((batch["actions"].shape[0], 1), i / flow_steps)
+                vels = self.network.select("actor")(
+                    batch["next_observations"], batch[goal_key], action, t
+                )
+                action = action + vels / flow_steps
+            return jnp.clip(action, -1, 1)
+
+        if pe_type == "rpg":
+            dist = self.network.select("actor")(
+                batch["next_observations"], batch[goal_key]
+            )
+            return jnp.clip(dist.mode(), -1, 1)
+
+        return batch["next_actions"]
+
+    def critic_loss(self, batch, grad_params):
+        goal_key, _q_logits, pred_z, qs, target_z, _tr_loss = self._log_trl_components(
+            batch, grad_params
+        )
+
+        improve = jax.lax.stop_gradient(target_z > pred_z)
+        tr_loss = jnp.where(
+            improve,
+            optax.huber_loss(pred_z, target_z, delta=self.config["log_huber_delta"]),
+            0.0,
+        )
+
+        log_discount = jnp.log(self.config["discount"])
+        mc_target_z = jax.lax.stop_gradient(
+            jnp.clip(
+                batch["value_offsets"][None, ...] * log_discount,
+                self.config["log_min"],
+                0.0,
+            )
+        )
+        mc_loss = optax.huber_loss(
+            pred_z, mc_target_z, delta=self.config["log_huber_delta"]
+        )
+
+        behavior_logits = self.network.select("target_critic")(
+            batch["next_observations"],
+            goals=batch[goal_key],
+            actions=batch["next_actions"],
+        )
+        actor_actions = self._actor_candidate_actions(batch, goal_key)
+        actor_logits = self.network.select("target_critic")(
+            batch["next_observations"],
+            goals=batch[goal_key],
+            actions=actor_actions,
+        )
+        behavior_q = jax.nn.sigmoid(behavior_logits)
+        actor_q = jax.nn.sigmoid(actor_logits)
+        max_next_q = jnp.maximum(behavior_q, actor_q)
+
+        td_target_q = self.config["discount"] * max_next_q
+        one_step_q = self.config["discount"] ** batch["value_offsets"][None, ...]
+        td_target_q = jnp.where(
+            (batch["value_offsets"] <= 1)[None, ...],
+            one_step_q,
+            td_target_q,
+        )
+        td_target_q = jax.lax.stop_gradient(jnp.clip(td_target_q, 1e-8, 1.0))
+        td_loss = optax.huber_loss(
+            qs, td_target_q, delta=self.config["td_huber_delta"]
+        )
+
+        tr_loss_mean = tr_loss.mean()
+        mc_loss_mean = mc_loss.mean()
+        td_loss_mean = td_loss.mean()
+        distill_loss = self._oracle_distill_loss(batch, grad_params, qs)
+        total_loss = (
+            self.config["tr_alpha"] * tr_loss_mean
+            + self.config["mc_alpha"] * mc_loss_mean
+            + self.config["td_alpha"] * td_loss_mean
+            + distill_loss
+        )
+
+        actor_better = jax.lax.stop_gradient(actor_q > behavior_q)
+        return total_loss, {
+            "total_loss": total_loss,
+            "q_loss": tr_loss_mean,
+            "mc_loss": mc_loss_mean,
+            "td_loss": td_loss_mean,
+            "distill_loss": distill_loss,
+            "improve_frac": improve.mean(),
+            "actor_better_frac": actor_better.mean(),
+            "z_mean": pred_z.mean(),
+            "z_target_mean": target_z.mean(),
+            "z_mc_target_mean": mc_target_z.mean(),
+            "q_mean": qs.mean(),
+            "q_behavior_target_mean": behavior_q.mean(),
+            "q_actor_target_mean": actor_q.mean(),
+            "q_td_target_mean": td_target_q.mean(),
+            "q_max": qs.max(),
+            "q_min": qs.min(),
+        }
+
+
+def get_config():
+    config = get_trl_log_config()
+    config["agent_name"] = "trl_log_relax_tdmax"
+    config["mc_alpha"] = 0.2
+    config["tr_alpha"] = 1.0
+    config["td_alpha"] = 1.0
+    config["td_huber_delta"] = 0.1
+    return config
