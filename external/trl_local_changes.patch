diff --git a/agents/msebc.py b/agents/msebc.py
new file mode 100644
index 0000000..5c5cb72
--- /dev/null
+++ b/agents/msebc.py
@@ -0,0 +1,136 @@
+from typing import Any
+
+import flax
+import flax.linen as nn
+import jax
+import jax.numpy as jnp
+import ml_collections as mlc
+import optax
+
+from utils.flax_utils import ModuleDict, TrainState, nonpytree_field
+from utils.networks import MLP
+
+
+class MSEBCActor(nn.Module):
+    """Deterministic goal-conditioned actor trained with MSE behavior cloning."""
+
+    hidden_dims: tuple[int, ...]
+    action_dim: int
+    layer_norm: bool = False
+
+    @nn.compact
+    def __call__(self, observations, goals=None):
+        inputs = [observations]
+        if goals is not None:
+            inputs.append(goals)
+        x = jnp.concatenate(inputs, axis=-1)
+        x = MLP(self.hidden_dims, activate_final=True, layer_norm=self.layer_norm)(x)
+        return nn.Dense(self.action_dim)(x)
+
+
+class MSEBCAgent(flax.struct.PyTreeNode):
+    """Minimal deterministic MSE BC baseline for official TRL screens."""
+
+    rng: Any
+    network: Any
+    config: Any = nonpytree_field()
+
+    def actor_loss(self, batch, grad_params):
+        pred_actions = self.network.select("actor")(
+            batch["observations"],
+            batch["actor_goals"],
+            params=grad_params,
+        )
+        actor_loss = jnp.mean((pred_actions - batch["actions"]) ** 2)
+        return actor_loss, {
+            "actor_loss": actor_loss,
+            "mse": actor_loss,
+            "pred_action_abs_mean": jnp.mean(jnp.abs(pred_actions)),
+            "target_action_abs_mean": jnp.mean(jnp.abs(batch["actions"])),
+        }
+
+    @jax.jit
+    def total_loss(self, batch, grad_params, rng=None):
+        loss, actor_info = self.actor_loss(batch, grad_params)
+        info = {f"actor/{key}": value for key, value in actor_info.items()}
+        return loss, info
+
+    @jax.jit
+    def update(self, batch):
+        new_rng, rng = jax.random.split(self.rng)
+
+        def loss_fn(grad_params):
+            return self.total_loss(batch, grad_params, rng=rng)
+
+        new_network, info = self.network.apply_loss_fn(loss_fn=loss_fn)
+        return self.replace(network=new_network, rng=new_rng), info
+
+    @jax.jit
+    def sample_actions(
+        self,
+        observations,
+        goals=None,
+        seed=None,
+        temperature=1.0,
+    ):
+        del seed, temperature
+        actions = self.network.select("actor")(observations, goals)
+        return jnp.clip(actions, -1, 1)
+
+    @classmethod
+    def create(
+        cls,
+        seed,
+        example_batch,
+        config,
+    ):
+        rng = jax.random.PRNGKey(seed)
+        rng, init_rng = jax.random.split(rng, 2)
+
+        ex_observations = example_batch["observations"]
+        ex_actions = example_batch["actions"]
+        ex_goals = example_batch["actor_goals"]
+        action_dim = ex_actions.shape[-1]
+
+        actor_def = MSEBCActor(
+            hidden_dims=config["actor_hidden_dims"],
+            action_dim=action_dim,
+            layer_norm=config["layer_norm"],
+        )
+        network_def = ModuleDict({"actor": actor_def})
+        network_params = network_def.init(
+            init_rng,
+            actor=(ex_observations, ex_goals),
+        )["params"]
+        network = TrainState.create(
+            network_def,
+            network_params,
+            tx=optax.adam(learning_rate=config["lr"]),
+        )
+
+        config["action_dim"] = action_dim
+        return cls(rng, network=network, config=flax.core.FrozenDict(**config))
+
+
+def get_config():
+    config = mlc.ConfigDict(
+        dict(
+            agent_name="msebc",
+            lr=3e-4,
+            batch_size=1024,
+            actor_hidden_dims=(1024,) * 4,
+            layer_norm=True,
+            discount=0.999,
+            action_dim=mlc.config_dict.placeholder(int),
+            dataset=mlc.ConfigDict(
+                dict(
+                    dataset_class="GCDataset",
+                    actor_p_curgoal=0.0,
+                    actor_p_trajgoal=1.0,
+                    actor_p_randomgoal=0.0,
+                    actor_geom_sample=True,
+                )
+            ),
+        )
+    )
+    return config
